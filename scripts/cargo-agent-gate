#!/usr/bin/env bash
set -euo pipefail

base_ref="${CARGO_AGENT_BASE:-}"
paths=()

usage() {
  cat <<'EOF'
usage: cargo-agent-gate [--base <rev>] [path ...]

Runs the default Cargo gate most useful for local agent edits. If paths are not
provided, the script derives changed files from branch, staged, unstaged, and
untracked changes. Crate-local Rust/TOML edits run package-scoped clippy and
nextest. Global Cargo/nextest lane changes escalate to workspace clippy and a
fast compile check.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --base)
      if [[ $# -lt 2 ]]; then
        echo "error: --base requires a revision" >&2
        usage >&2
        exit 2
      fi
      base_ref="$2"
      shift 2
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        paths+=("$1")
        shift
      done
      ;;
    -*)
      echo "unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
    *)
      paths+=("$1")
      shift
      ;;
  esac
done

workspace_root="$(git rev-parse --show-toplevel)"
cd "${workspace_root}"
CARGO="${CARGO:-./scripts/repo-cargo}"

resolve_base() {
  if [[ -n "${base_ref}" ]]; then
    printf '%s\n' "${base_ref}"
    return
  fi
  if git rev-parse --verify origin/main >/dev/null 2>&1; then
    printf '%s\n' "origin/main"
    return
  fi
  if git rev-parse --verify main >/dev/null 2>&1; then
    printf '%s\n' "main"
    return
  fi
  git rev-parse HEAD
}

collect_changed_paths() {
  if [[ "${#paths[@]}" -gt 0 ]]; then
    printf '%s\n' "${paths[@]}"
    return
  fi

  local base
  base="$(resolve_base)"
  if git merge-base "${base}" HEAD >/dev/null 2>&1; then
    local merge_base
    merge_base="$(git merge-base "${base}" HEAD)"
    git diff --name-only --diff-filter=ACMR "${merge_base}..HEAD" --
  fi
  git diff --name-only --diff-filter=ACMR --
  git diff --cached --name-only --diff-filter=ACMR --
  git ls-files --others --exclude-standard
}

is_rust_relevant_path() {
  case "$1" in
    *.rs|Cargo.toml|Cargo.lock|.cargo/config.toml|.config/nextest.toml|scripts/repo-cargo|scripts/cargo-*|scripts/rust-lane-doctor|scripts/test-rct.sh|Makefile)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

is_global_path() {
  case "$1" in
    Cargo.toml|Cargo.lock|.cargo/config.toml|.config/nextest.toml|scripts/repo-cargo|scripts/cargo-*|scripts/rust-lane-doctor|scripts/test-rct.sh|Makefile)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

package_name_for_dir() {
  local dir="$1"
  "$CARGO" metadata --format-version=1 --no-deps |
    node -e '
      const fs = require("fs");
      const path = require("path");
      const metadata = JSON.parse(fs.readFileSync(0, "utf8"));
      const root = process.argv[1];
      const dir = path.resolve(root, process.argv[2]);
      const pkg = metadata.packages.find((pkg) => path.dirname(pkg.manifest_path) === dir);
      if (pkg) process.stdout.write(pkg.name);
    ' "${workspace_root}" "${dir}"
}

mapfile -t changed < <(collect_changed_paths | awk 'NF' | sort -u)
relevant=()
global=0
for path in "${changed[@]}"; do
  if is_rust_relevant_path "${path}"; then
    relevant+=("${path}")
    if is_global_path "${path}"; then
      global=1
    fi
  fi
done

if [[ "${#relevant[@]}" -eq 0 ]]; then
  echo "Cargo agent gate: no Rust build-relevant changes detected."
  exit 0
fi

printf 'Cargo agent gate paths:\n'
printf '  %s\n' "${relevant[@]}"

if [[ "${global}" -eq 1 ]]; then
  echo "Global Rust build/test configuration changed; running workspace Cargo gate."
  "$CARGO" fast --no-run
  "$CARGO" clippy --workspace --all-targets --all-features -- -D warnings
  exit 0
fi

declare -A package_names=()
for path in "${relevant[@]}"; do
  if [[ "${path}" == */* ]]; then
    dir="${path%/*}"
  else
    dir="."
  fi
  while [[ -n "${dir}" && "${dir}" != "." ]]; do
    if [[ -f "${dir}/Cargo.toml" ]]; then
      pkg="$(package_name_for_dir "${dir}")"
      if [[ -n "${pkg}" ]]; then
        package_names["${pkg}"]=1
      fi
      break
    fi
    if [[ "${dir}" != */* ]]; then
      break
    fi
    dir="${dir%/*}"
  done
done

if [[ "${#package_names[@]}" -eq 0 ]]; then
  echo "Cargo agent gate: no crate-local changes detected."
  exit 0
fi

pkg_flags=()
for pkg in "${!package_names[@]}"; do
  pkg_flags+=("-p" "${pkg}")
done

printf 'Cargo agent gate packages:\n'
printf '  %s\n' "${!package_names[@]}"

"$CARGO" clippy "${pkg_flags[@]}" --all-targets --all-features -- -D warnings
"$CARGO" nextest run "${pkg_flags[@]}" --profile fast --no-tests=pass \
  --show-progress none --status-level none --final-status-level fail
